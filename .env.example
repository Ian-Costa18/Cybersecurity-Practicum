# Example environment file. Copy to .env and fill in real values.
# .env is git-ignored (it holds secrets); .env.example is committed.
#
# HOW THIS FILE IS LOADED — read this, there are two layers:
#
#   1. MSIG_* settings below are deploy-level Settings (pydantic-settings, ADR
#      0011). pydantic-settings reads .env automatically for THESE.
#   2. The secrets at the bottom are referenced from config.yaml via $ENV{VAR}
#      substitution (and MSIG_SEED_PASSWORD is read by the seed CLI). These read
#      the real process environment directly — a bare .env file does NOT populate
#      it, so they will be "unset" even though they're written here.
#
# To make BOTH layers resolve from this one file, run the app with uv's
# --env-file flag (it injects the file into the process environment):
#
#       uv run --env-file .env -m msig_proxy ...
#
# (or `set -a; source .env; set +a` in your shell). Plain `uv run` only covers
# layer 1.

# --- Deploy-level Settings (MSIG_ prefix) -------------------------------------
# All optional; defaults shown. Override only when needed.

# SQLAlchemy database URL. SQLite for the MVP (ADR 0011). The container overrides
# this to an absolute path on the /data volume (sqlite+pysqlite:////data/msig_proxy.db).
MSIG_DATABASE_URL=sqlite+pysqlite:///./msig_proxy.db
# Path to the application config file (parsed into AppConfig). Lives under config/.
MSIG_CONFIG_FILE=config/config.yaml
# Path to the credential-bearing users file read by the provision step (#100).
MSIG_USERS_FILE=config/users.yaml
# Deployment environment name (informational): dev | prod.
MSIG_ENV=dev
# Optional initial password for the account-seed CLI. If unset, the CLI prompts
# interactively. Read from the real environment, so it needs --env-file/export.
MSIG_SEED_PASSWORD=

# --- Secrets referenced by config.yaml via $ENV{...} --------------------------
# Names here must match the $ENV{...} references in your config.yaml
# (config.example.yaml uses exactly these).

# server.secret_key — min 16 chars; signs the session cookie. Required.
PROXY_SECRET_KEY=change-me-use-a-long-random-string
# notifications.email.smtp_password — omit if your SMTP server needs no auth.
SMTP_PASSWORD=
# services.<pypi service>.credentials.pypi_token — the PyPI upload token.
PYPI_TOKEN=
